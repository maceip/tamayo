# On-device (QEMU sifive_u / riscv64) One-More-MAYO blind signature demo.
#
# Runs sign_1 -> sign_2 -> sign_3 -> verify on bare-metal TamaGo against the
# embedded L1/L3/L5 reference vectors (tools/blind_loop_dump.cpp output) and
# prints whether the device reproduces the reference blinded message,
# preimage and proof byte-for-byte and accepts.
#
# Requires the TamaGo toolchain (tamago-go), qemu-system-riscv64, dtc, and
# python3. Set TAMAGO to the tamago `go` binary.
#
# The bios stage is generated per build by mkbios.py from the kernel's ELF
# entry point (the tamago-example prebuilt bios.bin hardcodes a stale
# _rt0_riscv64_tamago address and jumps into arbitrary code when the kernel
# is relinked).

TAMAGO ?= go
APP    := qemudemo
TEXT_START := 0x80010000

GOENV := GOOS=tamago GOARCH=riscv64 GOOSPKG=github.com/usbarmory/tamago
GOFLAGS := -tags sifive_u,gvisor,semihosting,linkramsize -trimpath \
           -ldflags "-s -w -T $(TEXT_START) -R 0x1000"

TGDIR := $(shell $(TAMAGO) list -m -f '{{.Dir}}' github.com/usbarmory/tamago)
DTS   := $(TGDIR)/board/qemu/sifive_u/qemu-riscv64-sifive_u.dts
BIOS  ?= bios.bin # generated by mkbios.py from $(APP)'s ELF entry

QEMU ?= qemu-system-riscv64 -machine sifive_u -m 16G -nographic -monitor none \
        -semihosting -serial stdio -net none -dtb qemu16g.dtb -bios $(BIOS)

$(APP):
	$(GOENV) $(TAMAGO) build $(GOFLAGS) -o $(APP)

$(BIOS): $(APP)
	python3 mkbios.py $(APP) $(BIOS)

# 16 GiB memory node (stock sifive_u dts caps RAM at 128 MiB; the linkramsize
# override in ramsize.go raises RamSize to 15.75 GiB to match). The L3/L5
# signer+verifier peak well above the 4 GiB that sufficed for L1 alone.
qemu16g.dtb:
	sed 's/0x00 0x8000000>/0x04 0x0>/' $(DTS) > qemu16g.dts
	dtc -I dts -O dtb qemu16g.dts -o qemu16g.dtb 2>/dev/null

qemu: $(APP) $(BIOS) qemu16g.dtb
	$(QEMU) -kernel $(APP)

clean:
	rm -f $(APP) $(BIOS) qemu16g.dts qemu16g.dtb
